{
  "name": "faircroft-coreone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "description": "FairCroft CoreOne roleplay CAD/MDT and civilian government portal.",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "prisma generate && next build && tsc --project tsconfig.server.json",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "railway:release": "prisma migrate deploy",
    "railway:start": "node dist/server.js"
  },
  "dependencies": {
    "@prisma/client": "6",
    "bcryptjs": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "^4.19.2",
    "helmet": "latest",
    "jsonwebtoken": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sanitize-html": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest",
    "tsx": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/sanitize-html": "latest",
    "eslint": "^9.39.1",
    "eslint-config-next": "latest",
    "prisma": "6",
    "typescript": "latest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
