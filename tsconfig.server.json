{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "isolatedModules": false,
    "incremental": false,
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["server.ts", "src/server/**/*.ts", "src/server/**/*.tsx"]
}
