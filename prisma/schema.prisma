generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  unverified_civ
  civilian
  pending_department
  government_employee
  police
  sheriff
  fire
  ems
  dispatcher
  department_supervisor
  site_admin
  owner
}

enum DepartmentType {
  government
  police
  sheriff
  fire
  ems
  dispatch
}

enum ApplicationStatus {
  pending
  approved
  denied
}

enum UnitStatus {
  TEN_8_AVAILABLE
  TEN_6_BUSY
  TEN_7_OUT_OF_SERVICE
  TEN_23_ON_SCENE
  TEN_97_EN_ROUTE
  TEN_15_TRANSPORTING
  CODE_4_CLEAR
  PRIORITY_RESPONSE
}

enum Call911Status {
  queued
  accepted
  converted
  closed
  cancelled
}

enum CadCallStatus {
  pending
  active
  assigned
  on_scene
  closed
  cancelled
}

enum PriorityLevel {
  low
  routine
  priority
  emergency
}

enum RecordStatus {
  active
  inactive
  expired
  revoked
  closed
  voided
}

enum ReportStatus {
  draft
  submitted
  approved
  voided
}

model User {
  id                  String                 @id @default(cuid())
  email               String                 @unique
  username            String?                @unique
  passwordHash        String
  name                String
  phone               String?
  role                UserRole               @default(unverified_civ)
  suspended           Boolean                @default(false)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  profile             CivilianProfile?
  applications        DepartmentApplication[]
  reviewedApplications DepartmentApplication[] @relation("ApplicationReviewer")
  governmentApplications GovernmentApplication[] @relation("GovernmentApplicationUser")
  reviewedGovernmentApplications GovernmentApplication[] @relation("GovernmentApplicationReviewer")
  memberships         DepartmentMembership[]
  vehicles            Vehicle[]
  licenses            License[]
  permits             Permit[]
  warrantsCreated     Warrant[]              @relation("WarrantCreator")
  citations           Citation[]             @relation("CitationUser")
  citationsIssued     Citation[]             @relation("CitationOfficer")
  reports             IncidentReport[]       @relation("IncidentAuthor")
  arrestReports       ArrestReport[]         @relation("ArrestOfficer")
  fireReports         FireReport[]           @relation("FireAuthor")
  emsReports          EMSReport[]            @relation("EmsAuthor")
  cadCallsCreated     CadCall[]              @relation("CadCallCreator")
  cadCallsAccepted    CadCall[]              @relation("CadCallAcceptor")
  callsAccepted       Call911[]              @relation("Call911Acceptor")
  cadCallNotes        CadCallNote[]          @relation("CadCallNoteAuthor")
  cadStatusHistory    CadStatusHistory[]     @relation("CadStatusActor")
  dispatchLogs        DispatchLog[]          @relation("DispatchLogDispatcher")
  units               CadUnit[]
  assignmentsMade     UnitAssignment[]       @relation("AssignmentDispatcher")
  bolosCreated        Bolo[]                 @relation("BoloCreator")
  auditLogs           AuditLog[]             @relation("AuditActor")
  calls                Call911[]             @relation("Call911Caller")
  notifications       Notification[]
  sessions            Session[]
  dispatchMessages    DispatchMessage[]
  announcements        GovernmentAnnouncement[] @relation("AnnouncementAuthor")
  bulletins            DepartmentBulletin[]   @relation("BulletinAuthor")
  trainingAssigned     TrainingRecord[]       @relation("TrainingAssigner")
  trainingRecords      TrainingRecord[]       @relation("TrainingUser")
  radioLogs            RadioLog[]
  shiftLogs            ShiftLog[]
  systemSettings       SystemSetting[]        @relation("SystemSettingUpdater")
  serverConfigurations ServerConfiguration[]  @relation("ServerConfigurationUpdater")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([suspended])
  @@index([createdAt])
}

model CivilianProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  address     String?
  city        String?  @default("FairCroft")
  state       String?  @default("FC")
  postalCode  String?
  phone       String?
  characterPhotoUrl String?
  characterPhotoNoticeAccepted Boolean @default(false)
  verificationStatus String @default("unverified")
  passportNumber String? @unique
  passportStatus RecordStatus @default(inactive)
  notes       String?
  recordFlags String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lastName, firstName])
  @@index([city, state])
  @@index([verificationStatus])
  @@index([passportNumber])
}

model Department {
  id           String                  @id @default(cuid())
  name         String
  code         String                  @unique
  type         DepartmentType
  description  String?
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  ranks        Rank[]
  applications DepartmentApplication[]
  memberships  DepartmentMembership[]
  units        CadUnit[]
  reports      IncidentReport[]
  cadCalls     CadCall[]
  assignments  UnitAssignment[]
  bulletins    DepartmentBulletin[]
  trainingRecords TrainingRecord[]
  radioLogs    RadioLog[]
  shiftLogs    ShiftLog[]

  @@index([type])
  @@index([isActive])
}

model DepartmentApplication {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId   String
  department     Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  desiredRole    UserRole?
  statement      String
  experience     String?
  status         ApplicationStatus @default(pending)
  decisionReason String?
  reviewedById   String?
  reviewedBy     User?             @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
  submittedAt    DateTime          @default(now())
  reviewedAt     DateTime?

  @@unique([userId, departmentId, status])
  @@index([status])
  @@index([submittedAt])
  @@index([departmentId, status])
}

model DepartmentMembership {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  rankId       String?
  rank         Rank?      @relation(fields: [rankId], references: [id])
  role         UserRole
  jobTitle     String?
  division     String?
  station      String?
  callSign     String?
  badgeNumber  String?
  active       Boolean    @default(true)
  joinedAt     DateTime   @default(now())

  @@unique([userId, departmentId])
  @@index([departmentId, active])
  @@index([userId, active])
  @@index([role])
  @@index([jobTitle])
}

model GovernmentApplication {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation("GovernmentApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  type           String
  status         ApplicationStatus @default(pending)
  payload        Json              @default("{}")
  decisionReason String?
  reviewedById   String?
  reviewedBy     User?             @relation("GovernmentApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  submittedAt    DateTime          @default(now())
  reviewedAt     DateTime?

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([submittedAt])
}

model Rank {
  id            String                 @id @default(cuid())
  departmentId  String
  department    Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name          String
  level         Int                    @default(1)
  permissions   Json                   @default("{}")
  memberships   DepartmentMembership[]

  @@unique([departmentId, name])
  @@index([departmentId, level])
}

model Vehicle {
  id                 String       @id @default(cuid())
  ownerId            String?
  owner              User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  make               String
  model              String
  year               Int
  color              String
  plate              String       @unique
  vin                String?      @unique
  registrationStatus RecordStatus @default(active)
  expiresAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([ownerId])
  @@index([plate])
  @@index([registrationStatus])
  @@index([expiresAt])
}

model License {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  number       String       @unique
  class        String       @default("D")
  status       RecordStatus @default(active)
  issuedAt     DateTime     @default(now())
  expiresAt    DateTime?
  restrictions String?

  @@index([userId])
  @@index([number])
  @@index([status])
  @@index([expiresAt])
}

model Permit {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  number    String       @unique
  status    RecordStatus @default(active)
  issuedAt  DateTime     @default(now())
  expiresAt DateTime?
  notes     String?

  @@index([userId])
  @@index([number])
  @@index([status])
  @@index([type])
}

model Warrant {
  id            String       @id @default(cuid())
  warrantNumber String       @unique @default(cuid())
  subjectId     String?
  subjectName   String
  dateOfBirth   DateTime?
  charges       String
  issuingCourt  String       @default("FairCroft Municipal Court")
  status        RecordStatus @default(active)
  severity      PriorityLevel @default(routine)
  issuedAt      DateTime     @default(now())
  createdById   String?
  createdBy     User?        @relation("WarrantCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedAt      DateTime     @updatedAt

  @@index([warrantNumber])
  @@index([subjectName])
  @@index([status])
  @@index([severity])
  @@index([issuedAt])
}

model Citation {
  id          String       @id @default(cuid())
  citationNumber String    @unique @default(cuid())
  userId      String?
  user        User?        @relation("CitationUser", fields: [userId], references: [id], onDelete: SetNull)
  subjectName String
  officerId   String?
  officer     User?        @relation("CitationOfficer", fields: [officerId], references: [id], onDelete: SetNull)
  statute     String
  description String
  fineCents   Int          @default(0)
  status      RecordStatus @default(active)
  issuedAt    DateTime     @default(now())
  location    String?

  @@index([citationNumber])
  @@index([userId])
  @@index([officerId])
  @@index([subjectName])
  @@index([status])
  @@index([issuedAt])
}

model IncidentReport {
  id           String       @id @default(cuid())
  cadCallId    String?
  cadCall      CadCall?     @relation(fields: [cadCallId], references: [id], onDelete: SetNull)
  authorId     String
  author       User         @relation("IncidentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  reportNumber String       @unique
  title        String
  narrative    String
  status       ReportStatus @default(submitted)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([reportNumber])
  @@index([cadCallId])
  @@index([authorId])
  @@index([departmentId])
  @@index([status])
  @@index([createdAt])
}

model ArrestReport {
  id                 String       @id @default(cuid())
  cadCallId          String?
  cadCall            CadCall?     @relation(fields: [cadCallId], references: [id], onDelete: SetNull)
  arrestingOfficerId String
  arrestingOfficer   User         @relation("ArrestOfficer", fields: [arrestingOfficerId], references: [id], onDelete: Cascade)
  subjectName         String
  charges             String
  narrative           String
  bookingNumber       String       @unique
  reportNumber        String       @unique @default(cuid())
  status              ReportStatus @default(submitted)
  createdAt           DateTime     @default(now())

  @@index([reportNumber])
  @@index([bookingNumber])
  @@index([cadCallId])
  @@index([arrestingOfficerId])
  @@index([subjectName])
  @@index([status])
}

model FireReport {
  id           String       @id @default(cuid())
  cadCallId    String?
  cadCall      CadCall?     @relation(fields: [cadCallId], references: [id], onDelete: SetNull)
  authorId     String
  author       User         @relation("FireAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reportNumber String       @unique @default(cuid())
  incidentType String
  cause        String?
  actions      String
  narrative    String
  status       ReportStatus @default(submitted)
  createdAt    DateTime     @default(now())

  @@index([reportNumber])
  @@index([cadCallId])
  @@index([authorId])
  @@index([incidentType])
  @@index([status])
}

model EMSReport {
  id             String       @id @default(cuid())
  cadCallId      String?
  cadCall        CadCall?     @relation(fields: [cadCallId], references: [id], onDelete: SetNull)
  authorId       String
  author         User         @relation("EmsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reportNumber   String       @unique @default(cuid())
  patientName    String
  patientAge     Int?
  chiefComplaint String
  careProvided   String
  disposition    String
  roleplayOnly   Boolean      @default(true)
  status         ReportStatus @default(submitted)
  createdAt      DateTime     @default(now())

  @@index([reportNumber])
  @@index([cadCallId])
  @@index([authorId])
  @@index([status])
}

model Call911 {
  id             String        @id @default(cuid())
  callNumber     String        @unique @default(cuid())
  callerId       String?
  caller         User?         @relation("Call911Caller", fields: [callerId], references: [id], onDelete: SetNull)
  emergencyType  String
  location       String
  description    String
  callerName     String
  callbackNumber String
  status         Call911Status @default(queued)
  priority       PriorityLevel @default(emergency)
  acceptedById   String?
  acceptedBy     User?         @relation("Call911Acceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  acceptedAt     DateTime?
  createdAt      DateTime      @default(now())
  cadCall        CadCall?
  dispatchLogs   DispatchLog[]

  @@index([callNumber])
  @@index([callerId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model CadCall {
  id          String           @id @default(cuid())
  call911Id   String?          @unique
  call911     Call911?         @relation(fields: [call911Id], references: [id], onDelete: SetNull)
  departmentId String?
  department  Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  callNumber  String           @unique
  type        String
  location    String
  description String
  priority    PriorityLevel    @default(routine)
  status      CadCallStatus    @default(active)
  createdById String?
  createdBy   User?            @relation("CadCallCreator", fields: [createdById], references: [id], onDelete: SetNull)
  acceptedById String?
  acceptedBy  User?            @relation("CadCallAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  closedAt    DateTime?
  assignments UnitAssignment[]
  incidentReports IncidentReport[]
  arrestReports   ArrestReport[]
  fireReports     FireReport[]
  emsReports      EMSReport[]
  notes           CadCallNote[]
  statusHistory   CadStatusHistory[]
  dispatchLogs    DispatchLog[]
  radioLogs       RadioLog[]

  @@index([callNumber])
  @@index([departmentId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model CadUnit {
  id              String           @id @default(cuid())
  departmentId    String
  department      Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  unitNumber      String           @unique
  status          UnitStatus       @default(TEN_8_AVAILABLE)
  currentLocation String?
  isPrimary       Boolean          @default(false)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignments     UnitAssignment[]
  radioLogs       RadioLog[]
  shiftLogs       ShiftLog[]

  @@index([departmentId])
  @@index([userId])
  @@index([unitNumber])
  @@index([status])
  @@index([active])
}

model UnitAssignment {
  id           String    @id @default(cuid())
  cadCallId    String
  cadCall      CadCall   @relation(fields: [cadCallId], references: [id], onDelete: Cascade)
  cadUnitId    String
  cadUnit      CadUnit   @relation(fields: [cadUnitId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedById String?
  assignedBy   User?     @relation("AssignmentDispatcher", fields: [assignedById], references: [id], onDelete: SetNull)
  status       String    @default("assigned")
  assignedAt   DateTime  @default(now())
  clearedAt    DateTime?

  @@unique([cadCallId, cadUnitId])
  @@index([departmentId])
  @@index([cadUnitId])
  @@index([status])
  @@index([assignedAt])
}

model Bolo {
  id                 String       @id @default(cuid())
  boloNumber         String       @unique @default(cuid())
  title              String
  description        String
  plate              String?
  personName         String?
  vehicleDescription String?
  status             RecordStatus @default(active)
  createdById        String?
  createdBy          User?        @relation("BoloCreator", fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([boloNumber])
  @@index([plate])
  @@index([personName])
  @@index([status])
  @@index([createdAt])
}

model DispatchMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String   @default("dispatch")
  body      String
  createdAt DateTime @default(now())

  @@index([channel])
  @@index([createdAt])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   @default("system")
  read      Boolean  @default(false)
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([type])
  @@index([createdAt])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId    String    @unique
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime?
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId])
  @@index([tokenId])
  @@index([expiresAt])
}

model CadCallNote {
  id        String   @id @default(cuid())
  cadCallId String
  cadCall   CadCall  @relation(fields: [cadCallId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation("CadCallNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([cadCallId])
  @@index([authorId])
  @@index([createdAt])
}

model CadStatusHistory {
  id         String         @id @default(cuid())
  cadCallId  String
  cadCall    CadCall        @relation(fields: [cadCallId], references: [id], onDelete: Cascade)
  fromStatus CadCallStatus?
  toStatus   CadCallStatus
  actorId    String?
  actor      User?          @relation("CadStatusActor", fields: [actorId], references: [id], onDelete: SetNull)
  note       String?
  createdAt  DateTime       @default(now())

  @@index([cadCallId])
  @@index([toStatus])
  @@index([actorId])
  @@index([createdAt])
}

model DispatchLog {
  id           String   @id @default(cuid())
  cadCallId    String?
  cadCall      CadCall? @relation(fields: [cadCallId], references: [id], onDelete: Cascade)
  call911Id    String?
  call911      Call911? @relation(fields: [call911Id], references: [id], onDelete: SetNull)
  dispatcherId String?
  dispatcher   User?    @relation("DispatchLogDispatcher", fields: [dispatcherId], references: [id], onDelete: SetNull)
  action       String
  message      String
  createdAt    DateTime @default(now())

  @@index([cadCallId])
  @@index([call911Id])
  @@index([dispatcherId])
  @@index([action])
  @@index([createdAt])
}

model GovernmentAnnouncement {
  id          String        @id @default(cuid())
  title       String
  body        String
  audience    String        @default("all")
  priority    PriorityLevel @default(routine)
  active      Boolean       @default(true)
  authorId    String?
  author      User?         @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  publishedAt DateTime      @default(now())
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([audience])
  @@index([active])
  @@index([priority])
  @@index([publishedAt])
}

model DepartmentBulletin {
  id           String        @id @default(cuid())
  departmentId String
  department   Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  authorId     String?
  author       User?         @relation("BulletinAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  title        String
  body         String
  priority     PriorityLevel @default(routine)
  active       Boolean       @default(true)
  expiresAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([departmentId, active])
  @@index([priority])
  @@index([createdAt])
}

model TrainingRecord {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("TrainingUser", fields: [userId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedById String?
  assignedBy   User?       @relation("TrainingAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  title        String
  description  String?
  status       String      @default("assigned")
  completedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([departmentId])
  @@index([status])
  @@index([createdAt])
}

model RadioLog {
  id           String      @id @default(cuid())
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  cadCallId    String?
  cadCall      CadCall?    @relation(fields: [cadCallId], references: [id], onDelete: SetNull)
  unitId       String?
  unit         CadUnit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel      String      @default("dispatch")
  code         String?
  message      String
  createdAt    DateTime    @default(now())

  @@index([departmentId])
  @@index([cadCallId])
  @@index([unitId])
  @@index([userId])
  @@index([channel])
  @@index([createdAt])
}

model ShiftLog {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unitId       String?
  unit         CadUnit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  status       String      @default("on_duty")
  clockInAt    DateTime    @default(now())
  clockOutAt   DateTime?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([departmentId])
  @@index([unitId])
  @@index([status])
  @@index([clockInAt])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json     @default("{}")
  updatedById String?
