DATABASE_URL="postgresql://username:password@host:5432/faircroft"
PORT=3000
NODE_ENV=development
RAILWAY_ENVIRONMENT=local
JWT_SECRET="replace-with-a-long-random-secret"
SECRET_KEY="replace-with-another-long-random-secret"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"
RUN_MIGRATIONS_ON_START="false"
SEED_ON_START="false"
PRISMA_LOG="false"
AUTH_DIAGNOSTICS_ENABLED="false"
OWNER_EMAIL="owner@faircroft.local"
OWNER_PASSWORD="set-a-private-owner-password"
OWNER_NAME="FairCroft Owner"
OWNER_SETUP_TOKEN="temporary-recovery-token-remove-after-use"
